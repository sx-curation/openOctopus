# ── Standard OpenAI (original CLI mode) ───────────────────────────────────
OPENAI_API_KEY=sk-...
MODEL=gpt-4o

# ── Azure OpenAI (Target 1 / 2 / 3: ACA / Foundry / Copilot) ──────────────
# Uncomment and fill in when deploying to Azure
# PROVIDER=azure_openai
# AZURE_OPENAI_API_KEY=
# AZURE_OPENAI_ENDPOINT=https://<resource>.openai.azure.com/
# AZURE_OPENAI_API_VERSION=2024-02-01
# AZURE_OPENAI_DEPLOYMENT=gpt-4o

# ── Data APIs ──────────────────────────────────────────────────────────────
FMP_API_KEY=your_fmp_key_here

# ── SEC EDGAR user-agent (update to your real org email in production) ─────
# EDGAR_IDENTITY=openoctopus research@yourcompany.com

# ── Azure AI Foundry (Target 2) ────────────────────────────────────────────
# AZURE_AI_PROJECT_CONNECTION_STRING=
# OPENOCTOPUS_AGENT_ID=

# ── GitHub Copilot Extension (Target 3) ────────────────────────────────────
# VERIFY_GITHUB_TOKEN=true
