# Azure OpenAI Configuration
# Replace with your actual credentials — NEVER commit real keys

OPENAI_API_KEY=your-azure-openai-api-key-here

BASE_URL=https://your-resource.openai.azure.com/openai/v1

MODEL=gpt-4o-mini

#FMP_API_KEY=your_fmp_key_here

# === Azure OpenAI (when using AzureOpenAI client) ===
# AZURE_OPENAI_ENDPOINT=https://your-resource.openai.azure.com
# AZURE_OPENAI_API_KEY=your-azure-key-here
# AZURE_OPENAI_API_VERSION=2024-12-01-preview

# === LLM Provider Fallback ===
# Controls which AI backend to use. Default: auto (tries Azure → OpenAI → Ollama)
# Options: auto | azure | openai | ollama | free-claude
# LLM_PROVIDER=auto

# Ollama local model (fallback when cloud providers unavailable)
# Start Ollama: https://ollama.ai — then: ollama pull llama3.2
# OLLAMA_BASE_URL=http://localhost:11434/v1
# OLLAMA_MODEL=llama3.2

# free-claude-code proxy (optional Ollama middleware with Admin UI)
# Install: uv tool install git+https://github.com/Alishahryar1/free-claude-code.git
# Start: free-claude  →  Admin UI at http://localhost:8082/admin
# FREE_CLAUDE_PROXY_URL=http://localhost:8082

# Circuit breaker: auto-fallback after N consecutive failures (default: 3)
# Resets primary after 600 seconds
# LLM_FALLBACK_ENABLED=true
# LLM_CIRCUIT_BREAKER_THRESHOLD=3
# LLM_CIRCUIT_BREAKER_RESET_SECONDS=600

